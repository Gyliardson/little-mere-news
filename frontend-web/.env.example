# ==========================================
# Little Mere News - Frontend Example Config
# ==========================================
# Rename this file to ".env.local" and fill in your actual credentials.

# Public Supabase Keys (Accessible on the client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Private Server Keys (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Phantom Admin Security
# The secret URL segment for the administrative dashboard.
ADMIN_PHANTOM_PATH=your-secret-path-slug
